# .gitignore for UNSW-NB15 SIEM project

# ── Data (large files — don't commit) ─────────────────────────────────────────
data/raw/
data/processed/
*.parquet
*.csv
!data/download_data.py

# ── Model artifacts ────────────────────────────────────────────────────────────
*.joblib
*.pkl
*.pt
*.pth
models/saved/

# ── Reports (generated, not source) ───────────────────────────────────────────
reports/incidents/*.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
dist/
build/
*.egg-info/
.eggs/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDEs ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs / OS ──────────────────────────────────────────────────────────────────
*.log
.DS_Store
Thumbs.db
.env
